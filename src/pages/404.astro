---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Página Não Encontrada | Klimba">
  <div class="min-h-[70vh] flex items-center justify-center bg-background-light py-16 px-4 relative overflow-hidden">
    
    <!-- Efeitos de Fundo (Blobs) -->
    <div class="absolute top-1/4 left-1/4 w-80 h-80 bg-primary/10 blur-[100px] rounded-full -translate-x-1/2 -translate-y-1/2"></div>
    <div class="absolute bottom-1/4 right-1/4 w-80 h-80 bg-primary/5 blur-[120px] rounded-full translate-x-1/2 translate-y-1/2"></div>

    <div class="max-w-md w-full text-center relative z-10 space-y-8">
      <!-- Iconografia 404 -->
      <div class="inline-flex items-center justify-center size-24 rounded-4xl bg-secondary/5 text-primary mb-2">
        <span class="material-symbols-outlined text-5xl">explore_off</span>
      </div>

      <!-- Texto -->
      <div class="space-y-3">
        <h1 class="text-7xl font-black text-secondary font-display tracking-tight">404</h1>
        <h2 class="text-2xl font-black text-secondary font-display">Página não encontrada</h2>
        <p class="text-text-muted text-sm max-w-sm mx-auto font-body">
          O insight ou página que você está procurando não existe ou foi movido para outro endereço.
        </p>
      </div>

      <!-- Ação -->
      <div class="pt-4">
        <a
          href="/"
          class="inline-flex h-14 items-center justify-center rounded-full bg-secondary text-primary hover:bg-primary hover:text-secondary px-10 text-xs font-black uppercase tracking-widest shadow-xl shadow-secondary/15 transition-all duration-300 hover:scale-105 active:scale-95"
        >
          Voltar para o Blog
          <span class="material-symbols-outlined ml-2 text-sm">arrow_forward</span>
        </a>
      </div>
    </div>
  </div>
</Layout>
