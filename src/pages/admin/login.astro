---
import Layout from '../../layouts/Layout.astro';
import { createClient } from '@supabase/supabase-js';
import { VITE_SUPABASE_URL, VITE_SUPABASE_ANON_KEY } from 'astro:env/server';

let errorMessage = '';

// Se já houver token válido, redireciona para o admin direto
const token = Astro.cookies.get('sb-access-token')?.value;
if (token) {
  const supabase = createClient(VITE_SUPABASE_URL, VITE_SUPABASE_ANON_KEY);
  const { data: { user } } = await supabase.auth.getUser(token);
  if (user) {
    return Astro.redirect('/admin');
  }
}

if (Astro.request.method === 'POST') {
  try {
    const formData = await Astro.request.formData();
    const email = formData.get('email')?.toString() || '';
    const password = formData.get('password')?.toString() || '';

    if (!email || !password) {
      errorMessage = 'Por favor, preencha todos os campos.';
    } else {
      const supabase = createClient(VITE_SUPABASE_URL, VITE_SUPABASE_ANON_KEY, {
        auth: { persistSession: false }
      });

      const { data, error } = await supabase.auth.signInWithPassword({
        email,
        password,
      });

      if (error) {
        errorMessage = 'Credenciais inválidas. Verifique seu e-mail e senha.';
      } else if (data.session) {
        // Guardar sessão em cookies httpOnly e redirecionar
        Astro.cookies.set('sb-access-token', data.session.access_token, { path: '/', httpOnly: true, secure: true });
        Astro.cookies.set('sb-refresh-token', data.session.refresh_token, { path: '/', httpOnly: true, secure: true });
        return Astro.redirect('/admin');
      }
    }
  } catch (err) {
    console.error("Login error:", err);
    errorMessage = 'Ocorreu um erro ao processar o login.';
  }
}
---

<Layout title="Acesso Restrito | Klimba Admin">
  <div class="min-h-[75vh] flex items-center justify-center bg-background-light py-12 px-4 sm:px-6 lg:px-8 relative overflow-hidden">
    <div class="absolute top-0 right-0 w-96 h-96 bg-primary/10 blur-[120px] rounded-full -mr-20 -mt-20"></div>
    <div class="absolute bottom-0 left-0 w-96 h-96 bg-primary/5 blur-[120px] rounded-full -ml-20 -mb-20"></div>

    <div class="max-w-md w-full space-y-8 bg-white p-10 rounded-4xl border border-gray-100 shadow-2xl relative z-10">
      <div class="text-center">
        <a href="/" class="inline-flex items-center gap-2 mb-6">
          <img src="/assets/klimba.svg" class="size-10" alt="Klimba Logo" />
          <span class="text-2xl font-black tracking-tight text-secondary font-display">Klimba</span>
        </a>
        <h2 class="text-3xl font-black text-secondary font-display">Painel do Administrador</h2>
        <p class="mt-2 text-sm text-text-muted">Acesso exclusivo para editores do blog</p>
      </div>

      <form class="mt-8 space-y-6" method="POST">
        {errorMessage && (
          <div class="bg-red-50 border border-red-200 text-red-700 px-4 py-3 rounded-2xl text-sm font-semibold flex items-center gap-2 animate-pulse">
            <span class="material-symbols-outlined text-lg">error</span>
            {errorMessage}
          </div>
        )}

        <div class="space-y-4">
          <div>
            <label for="email" class="block text-xs font-black uppercase tracking-widest text-secondary mb-2">E-mail</label>
            <input
              id="email"
              name="email"
              type="email"
              required
              class="w-full px-5 py-4 bg-background-light border border-transparent rounded-2xl text-sm focus:ring-2 focus:ring-primary/30 outline-none transition-all font-body text-secondary"
              placeholder="seuemail@klimba.com.br"
            />
          </div>
          <div>
            <label for="password" class="block text-xs font-black uppercase tracking-widest text-secondary mb-2">Senha</label>
            <input
              id="password"
              name="password"
              type="password"
              required
              class="w-full px-5 py-4 bg-background-light border border-transparent rounded-2xl text-sm focus:ring-2 focus:ring-primary/30 outline-none transition-all font-body text-secondary"
              placeholder="••••••••"
            />
          </div>
        </div>

        <div>
          <button
            type="submit"
            class="group relative w-full flex justify-center py-4 px-6 bg-secondary text-primary hover:bg-primary hover:text-secondary rounded-full text-sm font-black uppercase tracking-widest shadow-xl transition-all duration-300 active:scale-95"
          >
            Entrar no Painel
          </button>
        </div>
      </form>
    </div>
  </div>
</Layout>
