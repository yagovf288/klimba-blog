{
  "extends": "astro/tsconfigs/strict",
  "compilerOptions": {
    "jsx": "react-jsx",
    "jsxImportSource": "react",
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "node",
    "strictNullChecks": true,
    "allowJs": true,
    "skipLibCheck": true,
    "types": ["node"]
  }
}